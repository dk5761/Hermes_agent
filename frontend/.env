# Committed prod defaults.
#
# Local dev overrides go in `.env.local` (gitignored, loaded ONLY by
# `expo start` — never bundled into `eas update` or `eas build`). EAS
# server-side env vars (see `eas env:list --environment production`) are
# the canonical source for release builds; this file is the fallback for
# anyone running `expo start` or building locally without EAS.
EXPO_PUBLIC_API_URL=https://hermes.drshnk.dev
EXPO_PUBLIC_WS_URL=wss://hermes.drshnk.dev
