{
  "name": "frontend",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "prebuild": "expo prebuild --clean",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "ios:release": "expo run:ios --configuration Release",
