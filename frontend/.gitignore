# Dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Generated native projects (created by `expo prebuild`)
/ios
/android

# Native build artifacts
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.keystore

# CocoaPods (when ios/ is generated)
ios/Pods/
ios/build/
ios/*.xcworkspace/xcuserdata/
ios/*.xcodeproj/xcuserdata/
ios/*.xcodeproj/project.xcworkspace/xcuserdata/

# Android (when android/ is generated)
android/build/
android/app/build/
android/.gradle/
android/local.properties

# Metro
.metro-health-check*

# Debug logs
npm-debug.*
yarn-debug.*
yarn-error.*
pnpm-debug.*

# macOS
.DS_Store
*.pem

# Env files. `.env` holds committed prod defaults (EXPO_PUBLIC_* only,
# no secrets — those live in EAS server-side env vars). Local dev
# overrides go in `.env.local` (gitignored, loaded only by `expo start`).
.env.local
.env.*.local
.env.development
.env.production

# TypeScript
*.tsbuildinfo

# Uniwind generated type declarations (regenerated by metro on each start)
uniwind-types.d.ts

# Test coverage
coverage/

# ios
*.ipa