# Frontend env file convention
# ─────────────────────────────────────────────────────────────────────────
# `.env`             — committed prod defaults. Loaded everywhere
#                      (expo start, eas update, eas build).
# `.env.local`       — gitignored per-machine override. Loaded ONLY by
#                      `expo start`. Never bundled into eas update / build.
#                      Put your dev/LAN URL here.
# `.env.development` — gitignored, loaded when NODE_ENV=development.
# `.env.production`  — gitignored, loaded when NODE_ENV=production.
# EAS server env     — `eas env:create --environment production --name X
#                      --value Y`. Canonical for release builds; overrides
#                      committed `.env` at eas-update / eas-build time.
#
# To run against your local backend during dev, copy this file to
# `.env.local` and edit the values to match your LAN IP.
EXPO_PUBLIC_API_URL=http://127.0.0.1:8080
EXPO_PUBLIC_WS_URL=ws://127.0.0.1:8080
