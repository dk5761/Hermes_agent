# macOS / OS
.DS_Store
*.swp
*~

# Editors / IDEs
.vscode/
.idea/
*.code-workspace
.cursor/
.zed/

# Logs / debug
*.log
npm-debug.*
yarn-debug.*
yarn-error.*
pnpm-debug.*

# Local env files (per-app .env stays inside that app's gitignore)
.env.local
.env.*.local

# Obsidian Sync credentials — never commit. Template at obsidian-sync.env.example
/obsidian-sync.env

# Docker-managed runtime state — hermes home (state.db, cron, sessions,
# memory, secrets in its own .env, model cache). Never commit.
/data/

# Backups produced by scripts/backup-*.sh
/backups/

# Temp / scratch
/tmp/
*.tmp
