NODE_ENV=development
PORT=8080
HOST=127.0.0.1

DATABASE_URL=./data/gateway.db

JWT_SECRET=changeme-32-bytes-min
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=./data/blobs
STORAGE_BUCKET=hermes-mobile-local
STORAGE_SIGNED_URL_SECRET=changeme-32-bytes-min
STORAGE_SIGNED_URL_TTL_S=300

# S3 / S3-compat (MinIO etc). Required only when STORAGE_PROVIDER=s3.
# STORAGE_ENDPOINT empty = real AWS; set to e.g. http://127.0.0.1:9000 for MinIO.
# STORAGE_FORCE_PATH_STYLE=true for MinIO; usually false for AWS prod.
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_FORCE_PATH_STYLE=true
STORAGE_S3_CACHE_DIR=./data/cache/materialized

WS_EVENT_RETENTION_HOURS=24
WS_EVENT_POSTRUN_GRACE_HOURS=1

BOOTSTRAP_USERNAME=
BOOTSTRAP_PASSWORD=

# Hermes upstream
HERMES_LAUNCH_MODE=external
HERMES_BASE_URL=http://127.0.0.1:9119
HERMES_TOKEN=
HERMES_HOME=
HERMES_PYTHON=python3
HERMES_AGENT_DIR=
HERMES_PORT=9119
HERMES_SPAWN_RESTART_BACKOFF_MS=2000
HERMES_SPAWN_RESTART_MAX_BACKOFF_MS=60000
HERMES_REQUEST_TIMEOUT_MS=30000

# Phase 4.5: scanned-PDF OCR via system poppler + tesseract.
# Set OCR_ENABLED=false to disable. macOS: brew install poppler tesseract.
# Debian/Ubuntu: apt-get install -y poppler-utils tesseract-ocr tesseract-ocr-eng.
OCR_ENABLED=true
OCR_MAX_PAGES=10
OCR_DPI=200
OCR_TIMEOUT_MS=60000
OCR_LANGUAGES=eng
OCR_PDFTOPPM_BIN=pdftoppm
OCR_TESSERACT_BIN=tesseract

# Phase 6: push notifications + cron output watcher.
# EXPO_ACCESS_TOKEN: optional — set for high-volume sends or stricter rate-limits.
EXPO_ACCESS_TOKEN=
CRON_OUTPUT_WATCH_ENABLED=true
CRON_WATCH_POLL_MS=100
