{
  "name": "hermes-mobile-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Hermes mobile gateway (Phase 1 foundation)",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed:user": "tsx scripts/seed-user.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no linter yet'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.0.2",
    "argon2": "^0.41.1",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^5.0.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "expo-server-sdk": "^6.1.0",
    "fastify": "^5.2.1",
    "file-type": "^22.0.1",
    "jsonwebtoken": "^9.0.2",
    "pdf-parse": "^2.4.5",
    "pino": "^9.6.0",
    "sharp": "^0.34.5",
    "undici": "^6.25.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/pdf-parse": "^1.1.5",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "argon2",
      "sharp"
    ]
  }
}
