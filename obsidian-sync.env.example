# Copy this file to obsidian-sync.env and fill in the values.
# obsidian-sync.env is gitignored — never commit your real token/password.

# === Obtained from interactive first-run ===
# Run once:
#   docker compose run --rm --entrypoint get-token obsidian-sync
# Enter your Obsidian email + password (and MFA if enabled). Paste token here.
OBSIDIAN_AUTH_TOKEN=

# === Vault selection ===
# Exact, case-sensitive remote vault name (matches the name shown in Obsidian Sync settings).
VAULT_NAME=Drshnk

# === End-to-end encryption ===
# The encryption password set in Obsidian → Settings → Sync → "Encryption password".
# DISTINCT from your Obsidian account login password.
# Leave empty if your vault is not E2E-encrypted.
VAULT_PASSWORD=

# === Sync direction ===
# bidirectional  — full peer (default; uploads + downloads)
# pull-only      — download only, ignore local changes
# mirror-remote  — download only, REVERT local changes (destructive — use with caution)
SYNC_MODE=bidirectional
